{
  "fonts": {
    "family": "Loucos Lyne",
    "sizePx": 14,
    "faces": [
      {
        "family": "Loucos Lyne",
        "src": "/fonts/Loucos Lyne - thesimssansbold.otf",
        "weight": "700",
        "style": "normal"
      },
      {
        "family": "Loucos Lyne Small Caps",
        "src": "/fonts/Loucos Lyne - thesimssansboldsc.otf",
        "weight": "700",
        "style": "normal"
      }
    ]
  },
  "colors": {
    "panelBg": "#5e5ee8",
    "panelFg": "#dfe6f2",
    "accent": "rgba(90,120,190,.55)",
    "warn": "#e0b05f",
    "error": "#e57a7a",
    "buttonBg": "#bbd0f2",
    "buttonFg": "#eaf0fb",
    "outline": "#ffffff"
  },
  "shapes": {
    "radiusPx": 8,
    "outlineWidthPx": 2,
    "shadow": "0 3px 14px rgba(0,0,0,.35)"
  },
  "components": {
    "panel": {
      "background": "rgba(20,26,40,.82)",
      "foreground": "#dfe6f2",
      "radiusPx": 10,
      "shadow": "none",
      "fontFamily": "Loucos Lyne"
    },
    "button": {
      "background": "#c7a4f2",
      "foreground": "#eaf0fb",
      "accent": "rgba(90,120,190,.4)",
      "outline": "rgba(90,120,190,.4)",
      "radiusPx": 999,
      "outlineWidthPx": 0,
      "shadow": "none",
      "fontFamily": "Loucos Lyne"
    },
    "toast": {
      "background": "rgba(20,26,40,.92)",
      "foreground": "#eaf0fb",
      "accent": "#5a9fd6",
      "radiusPx": 10,
      "outlineWidthPx": 3,
      "shadow": "0 2px 10px rgba(0,0,0,.35)",
      "fontSizePx": 9,
      "fontFamily": "Loucos Lyne"
    },
    "actionMenu": {
      "background": "#dfe6f2",
      "foreground": "rgba(0,0,0,0.75)",
      "accent": "rgba(90,120,190,.4)",
      "outline": "rgba(0,0,0,0.75)",
      "radiusPx": 12,
      "outlineWidthPx": 2,
      "shadow": "0 4px 16px rgba(0,0,0,.4)",
      "fontSizePx": 9,
      "fontFamily": "Loucos Lyne",
      "marginPx": 0,
      "paddingXPx": 10,
      "paddingYPx": 7,
      "widthPx": 116,
      "heightPx": 48,
      "centerRadiusPx": 106
    },
    "card": {
      "radiusPx": 10
    },
    "bar": {
      "background": "rgba(255,255,255,.12)",
      "radiusPx": 4,
      "heightPx": 14
    },
    "phoneShell": {
      "radiusPx": 30,
      "outlineWidthPx": 2
    },
    "phoneTab": {
      "radiusPx": 999,
      "paddingXPx": 3,
      "paddingYPx": 7,
      "heightPx": 48
    },
    "accordionHeader": {
      "radiusPx": 999,
      "paddingXPx": 11,
      "paddingYPx": 7
    }
  },
  "layout": {
    "needs-panel": {
      "anchor": "tl",
      "offsetX": 5,
      "offsetY": 10,
      "accordion": "Needs"
    },
    "skills-panel": {
      "anchor": "tl",
      "offsetX": 150,
      "offsetY": 10,
      "accordion": "Skills"
    },
    "quest-panel": {
      "anchor": "bl",
      "offsetX": 5,
      "offsetY": 5
    },
    "time-bar": {
      "anchor": "tc",
      "offsetX": 0,
      "offsetY": 5
    },
    "activity-chip": {
      "anchor": "bc",
      "offsetX": 0,
      "offsetY": 80
    },
    "work-chip": {
      "anchor": "bc",
      "offsetX": 0,
      "offsetY": 14
    },
    "quest-toasts": {
      "anchor": "tc",
      "offsetX": 0,
      "offsetY": 80
    },
    "visa-chip": {
      "anchor": "br",
      "offsetX": 5,
      "offsetY": 10
    },
    "funds-chip": {
      "anchor": "br",
      "offsetX": 90,
      "offsetY": 10
    },
    "buy-button": {
      "anchor": "br",
      "offsetX": 5,
      "offsetY": 5
    },
    "wall-cut-button": {
      "anchor": "tr",
      "offsetX": 5,
      "offsetY": 50
    },
    "phone-button": {
      "anchor": "br",
      "offsetX": 8,
      "offsetY": 208
    },
    "buy-ghost-controls": {
      "anchor": "bc",
      "offsetX": 0,
      "offsetY": 14
    },
    "buy-selection-chips": {
      "anchor": "bc",
      "offsetX": 0,
      "offsetY": 14
    }
  },
  "accordions": [
    {
      "name": "Needs",
      "collapsedByDefault": true,
      "icon": "/icons/needs.svg",
      "showText": false
    },
    {
      "name": "Skills",
      "collapsedByDefault": true,
      "icon": "/icons/skills.svg",
      "showText": false
    }
  ]
}