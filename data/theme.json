    "panel": {
      "background": "rgba(20,26,40,.82)",
      "foreground": "#dfe6f2",
      "radiusPx": 10,
      "shadow": "none",
      "fontFamily": "/fonts/Loucos Lyne - thesimssansbold.otf"
    },
    "button": {
      "background": "#c7a4f2",
      "foreground": "#eaf0fb",
      "accent": "rgba(90,120,190,.4)",
      "outline": "rgba(90,120,190,.4)",
      "radiusPx": 999,
      "outlineWidthPx": 0,
      "shadow": "none",
      "fontFamily": "/fonts/Loucos Lyne - thesimssansbold.otf"
    },
    "toast": {
      "background": "rgba(20,26,40,.92)",
      "foreground": "#eaf0fb",
      "accent": "#5a9fd6",
      "radiusPx": 10,
      "outlineWidthPx": 3,
