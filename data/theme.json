{
  "fonts": {
    "family": "system-ui, sans-serif",
    "sizePx": 14
  },
  "colors": {
    "panelBg": "#5e5ee8",
    "panelFg": "#dfe6f2",
    "accent": "rgba(90,120,190,.55)",
    "warn": "#e0b05f",
    "error": "#e57a7a",
    "buttonBg": "#bbd0f2",
